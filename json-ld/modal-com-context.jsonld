{
  "@context": {
    "@vocab": "https://schema.org/",
    "modal": "https://modal.com/ns/",
    "Function": "modal:Function",
    "Sandbox": "modal:Sandbox",
    "App": "modal:App",
    "Volume": "modal:Volume",
    "Image": "modal:Image",
    "Secret": "modal:Secret",
    "Dict": "modal:Dict",
    "Queue": "modal:Queue",
    "Schedule": "modal:Schedule",
    "WebEndpoint": "modal:WebEndpoint",
    "FunctionCall": "modal:FunctionCall",
    "Workspace": "modal:Workspace",
    "Environment": "modal:Environment",
    "Token": "modal:Token",
    "gpu": "modal:gpu",
    "cpu": "modal:cpu",
    "memory": "modal:memory",
    "timeout": "modal:timeout",
    "retries": "modal:retries",
    "minContainers": "modal:minContainers",
    "maxContainers": "modal:maxContainers",
    "image": { "@id": "modal:image", "@type": "@id" },
    "volumes": { "@id": "modal:volumes", "@type": "@id", "@container": "@set" },
    "secrets": { "@id": "modal:secrets", "@type": "@id", "@container": "@set" },
    "schedule": "modal:schedule",
    "webUrl": { "@id": "modal:webUrl", "@type": "@id" },
    "appId": "modal:appId",
    "functionId": "modal:functionId",
    "sandboxId": "modal:sandboxId"
  }
}
