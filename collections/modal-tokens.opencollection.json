{
  "opencollection": "1.0.0",
  "info": {
    "name": "Modal Tokens and Workspace API",
    "version": "0.1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Tokens",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Tokens",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/tokens"
          },
          "docs": "List Tokens"
        },
        {
          "info": {
            "name": "Create Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.modal.com/v1/tokens",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new Modal token id and secret. The plaintext secret is\nreturned exactly once.\n"
        },
        {
          "info": {
            "name": "Revoke Token",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.modal.com/v1/tokens/:token_id",
            "params": [
              {
                "name": "token_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Revoke Token"
        }
      ]
    },
    {
      "info": {
        "name": "Environments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Environments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/environments"
          },
          "docs": "List Environments"
        },
        {
          "info": {
            "name": "Create Environment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.modal.com/v1/environments",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Environment"
        }
      ]
    },
    {
      "info": {
        "name": "Workspaces",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Current Workspace",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/workspaces/current"
          },
          "docs": "Get Current Workspace"
        }
      ]
    }
  ],
  "bundled": true
}