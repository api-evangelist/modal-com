{
  "opencollection": "1.0.0",
  "info": {
    "name": "Modal Web Endpoints API",
    "version": "0.1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "WebEndpoints",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Web Endpoints",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/web-endpoints"
          },
          "docs": "List Web Endpoints"
        },
        {
          "info": {
            "name": "Get Web Endpoint",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/web-endpoints/:endpoint_id",
            "params": [
              {
                "name": "endpoint_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Web Endpoint"
        },
        {
          "info": {
            "name": "Set Web Endpoint Custom URL Label",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.modal.com/v1/web-endpoints/:endpoint_id/labels",
            "params": [
              {
                "name": "endpoint_id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Set Web Endpoint Custom URL Label"
        }
      ]
    }
  ],
  "bundled": true
}