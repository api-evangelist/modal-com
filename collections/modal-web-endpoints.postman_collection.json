  "info": {
    "_postman_id": "22653db1-f39e-486d-902d-1aa4515f5d1c",
    "name": "Modal Web Endpoints API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Modal Web Endpoints — HTTP, ASGI, and WSGI surfaces exposed by Modal\nFunctions. Web Endpoints are produced by decorating a Modal Function\nwith `@modal.fastapi_endpoint`, `@modal.asgi_app`, `@modal.wsgi_app`,\nor `@modal.web_server` and are served from a Modal-issued URL.\nStreaming responses, WebSockets, and proxy-auth tokens are supported.\n\n\nContact Support:\n Name: Modal Labs",
      "type": "text/plain"
    }
  }
