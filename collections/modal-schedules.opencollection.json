{
  "opencollection": "1.0.0",
  "info": {
    "name": "Modal Schedules API",
    "version": "0.1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Schedules",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Schedules",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/schedules"
          },
          "docs": "List Schedules"
        },
        {
          "info": {
            "name": "Get Schedule",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/schedules/:schedule_id",
            "params": [
              {
                "name": "schedule_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get Schedule"
        },
        {
          "info": {
            "name": "List Schedule Runs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.modal.com/v1/schedules/:schedule_id/runs",
            "params": [
              {
                "name": "schedule_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List Schedule Runs"
        },
        {
          "info": {
            "name": "Trigger Schedule Run",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.modal.com/v1/schedules/:schedule_id/runs",
            "params": [
              {
                "name": "schedule_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Manually trigger an immediate run of the scheduled Function."
        }
      ]
    }
  ],
  "bundled": true
}