    "_postman_id": "feb9db3b-7164-4dcc-ae30-25ae80dec7d7",
    "name": "Modal Volumes API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Modal Volumes — a high-performance distributed file system for Modal\napplications, optimized for ML workflows. Volumes provide persistent\nstorage that can be attached to Functions and Sandboxes across\nregions, with explicit commit/reload semantics for write\nconsistency.\n\n\nContact Support:\n Name: Modal Labs",
      "type": "text/plain"
    }
