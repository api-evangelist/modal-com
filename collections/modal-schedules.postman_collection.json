  "info": {
    "_postman_id": "bbd7f6fd-c68b-4a6b-9067-9383689c5678",
    "name": "Modal Schedules API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Modal Schedules — periodic execution for Modal Functions. Modal\nsupports two scheduling primitives: `modal.Cron` (cron expressions\nwith timezone support) and `modal.Period` (fixed intervals between\nruns). Schedules are attached to deployed Functions via\n`@app.function(schedule=...)`.\n\n\nContact Support:\n Name: Modal Labs",
      "type": "text/plain"
    }
  }
